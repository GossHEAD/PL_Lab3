digraph "search" {
  label="search";
  labelloc=t;
  node [shape=record, fontname="monospace", fontsize=9];
  edge [fontname="monospace", fontsize=8];

  bb0 [label="entry (BB0)\li = 0\l", style=filled, fillcolor=lightgreen];
  bb1 [label="exit (BB1)", style=filled, fillcolor=lightyellow];
  bb2 [label="loop.cond (BB2)---\lcond: (i \< n)\l"];
  bb3 [label="loop.body (BB3)---\lcond: (arr[i] == target)\l"];
  bb4 [label="loop.exit (BB4)\li\l"];
  bb5 [label="if.then (BB5)"];
  bb6 [label="if.merge (BB6)\li = (i + 1)\l"];

  bb0 -> bb2;
  bb2 -> bb3 [label="true", color=green];
  bb2 -> bb4 [label="false", color=red];
  bb3 -> bb5 [label="true", color=green];
  bb3 -> bb6 [label="false", color=red];
  bb4 -> bb1;
  bb5 -> bb4;
  bb6 -> bb2;
}
