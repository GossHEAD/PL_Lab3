architecture StackVM {

registers:
    storage IP_reg[32];
    storage SP_reg[32];
    storage FP_reg[32];
    storage IO_reg[32];
    storage RV_tag[8];
    storage RV_val[64];
    storage STDIN_reg[72];
    storage STDOUT_reg[72];

    view ip         = IP_reg;
    view sp         = SP_reg;
    view fp         = FP_reg;
    view io         = IO_reg;
    view rv_tag     = RV_tag;
    view rv_val     = RV_val;
    view stdin_tag  = STDIN_reg[64..71];
    view stdin_val  = STDIN_reg[0..63];
    view stdout_tag = STDOUT_reg[64..71];
    view stdout_val = STDOUT_reg[0..63];
    view stdout_full = STDOUT_reg;

memory:
    range _code [0x00000000..0x0000FFFF] {
        cell = 8;
        endianess = little-endian;
        granularity = 0;
    }

    range _constants [0x00010000..0x0001FFFF] {
        cell = 8;
        endianess = little-endian;
        granularity = 0;
    }

    range _databank [0x00020000..0x0002FFFF] {
        cell = 8;
        endianess = little-endian;
        granularity = 0;
    }

    range _stack [0x00030000..0x0003FFFF] {
        cell = 8;
        endianess = little-endian;
        granularity = 0;
    }

instructions:

    encode imm32 field = immediate[32] data;
    encode addr32 field = immediate[32] offset;

    instruction push_int_op = { 00000001, imm32 as value } {
        sp = sp + 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = value;
        ip = ip + 5;
    };

    instruction push_bool_op = { 00000010, imm32 as value } {
        sp = sp + 9;
        _stack[sp - 9] = 0x02;
        _stack[sp - 8] = value;
        ip = ip + 5;
    };

    instruction push_char_op = { 00000011, imm32 as value } {
        sp = sp + 9;
        _stack[sp - 9] = 0x03;
        _stack[sp - 8] = value;
        ip = ip + 5;
    };

    instruction push_const_op = { 00000100, imm32 as idx } {
        sp = sp + 9;
        _stack[sp - 9] = 0x04;
        _stack[sp - 8] = idx;
        ip = ip + 5;
    };

    instruction push_none_op = { 00000101 } {
        sp = sp + 9;
        _stack[sp - 9] = 0x00;
        _stack[sp - 8] = 0;
        ip = ip + 1;
    };

    instruction load_local_op = { 00010000, imm32 as slot } {
        let off = slot * 9;
        sp = sp + 9;
        _stack[sp - 9] = _stack[fp + off];
        _stack[sp - 8] = _stack[(fp + off) + 1];
        ip = ip + 5;
    };

    instruction store_local_op = { 00010001, imm32 as slot } {
        let off = slot * 9;
        _stack[fp + off]       = _stack[sp - 9];
        _stack[(fp + off) + 1] = _stack[sp - 8];
        sp = sp - 9;
        ip = ip + 5;
    };

    instruction load_arg_op = { 00010010, imm32 as slot } {
        let off = slot * 9;
        sp = sp + 9;
        _stack[sp - 9] = _stack[(fp - 17) - off];
        _stack[sp - 8] = _stack[(fp - 16) - off];
        ip = ip + 5;
    };

    instruction store_arg_op = { 00010011, imm32 as slot } {
        let off = slot * 9;
        _stack[(fp - 17) - off]     = _stack[sp - 9];
        _stack[(fp - 16) - off]     = _stack[sp - 8];
        sp = sp - 9;
        ip = ip + 5;
    };

    instruction dup_op = { 00010100 } {
        _stack[sp]     = _stack[sp - 9];
        _stack[sp + 1] = _stack[sp - 8];
        sp = sp + 9;
        ip = ip + 1;
    };

    instruction pop_op = { 00010101 } {
        sp = sp - 9;
        ip = ip + 1;
    };

    instruction add_op = { 00100000 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a + b;
        ip = ip + 1;
    };

    instruction sub_op = { 00100001 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a - b;
        ip = ip + 1;
    };

    instruction mul_op = { 00100010 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a * b;
        ip = ip + 1;
    };

    instruction div_op = { 00100011 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a / b;
        ip = ip + 1;
    };

    instruction mod_op = { 00100100 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a % b;
        ip = ip + 1;
    };

    instruction neg_op = { 00100101 } {
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = 0 - _stack[sp - 8];
        ip = ip + 1;
    };

    instruction inc_op = { 00100110 } {
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = _stack[sp - 8] + 1;
        ip = ip + 1;
    };

    instruction dec_op = { 00100111 } {
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = _stack[sp - 8] - 1;
        ip = ip + 1;
    };

    instruction bit_and_op = { 00101000 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a & b;
        ip = ip + 1;
    };

    instruction bit_or_op = { 00101001 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a | b;
        ip = ip + 1;
    };

    instruction bit_xor_op = { 00101010 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a ^ b;
        ip = ip + 1;
    };

    instruction bit_shl_op = { 00101011 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a << b;
        ip = ip + 1;
    };

    instruction bit_shr_op = { 00101100 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = a >> b;
        ip = ip + 1;
    };

    instruction bit_not_op = { 00101101 } {
        _stack[sp - 9] = 0x01;
        _stack[sp - 8] = ~_stack[sp - 8];
        ip = ip + 1;
    };

    instruction log_and_op = { 00101110 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x02;
        if a != 0 then {
            if b != 0 then {
                _stack[sp - 8] = 1;
            } else {
                _stack[sp - 8] = 0;
            }
        } else {
            _stack[sp - 8] = 0;
        }
        ip = ip + 1;
    };

    instruction log_or_op = { 00101111 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x02;
        if a != 0 then {
            _stack[sp - 8] = 1;
        } else {
            if b != 0 then {
                _stack[sp - 8] = 1;
            } else {
                _stack[sp - 8] = 0;
            }
        }
        ip = ip + 1;
    };

    instruction log_not_op = { 00110000 } {
        _stack[sp - 9] = 0x02;
        if _stack[sp - 8] == 0 then {
            _stack[sp - 8] = 1;
        } else {
            _stack[sp - 8] = 0;
        }
        ip = ip + 1;
    };

    instruction cmp_eq_op = { 00110001 } {
        let b = _stack[sp - 8];
        let a = _stack[sp - 17];
        sp = sp - 9;
        _stack[sp - 9] = 0x02;
        if a == b then {
            _stack[sp - 8] = 1;
        } else {
            _stack[sp - 8] = 0;
        }
        ip = ip + 1;
    };

    instruction jmp_op = { 01000000, addr32 as target } {
        ip = target;
    };

    instruction call_op = { 01000011, addr32 as target } {
        sp = sp + 4;
        _stack[sp - 4] = (ip + 5) & 0xFF;
        _stack[sp - 3] = ((ip + 5) >> 8) & 0xFF;
        _stack[sp - 2] = ((ip + 5) >> 16) & 0xFF;
        _stack[sp - 1] = ((ip + 5) >> 24) & 0xFF;
        sp = sp + 4;
        _stack[sp - 4] = fp & 0xFF;
        _stack[sp - 3] = (fp >> 8) & 0xFF;
        _stack[sp - 2] = (fp >> 16) & 0xFF;
        _stack[sp - 1] = (fp >> 24) & 0xFF;
        fp = sp;
        ip = target;
    };

    instruction ret_op = { 01000100, imm32 as nargs } {
        rv_tag = _stack[sp - 9];
        rv_val = _stack[sp - 8];
        sp = fp;
        fp = _stack[sp - 4] | (_stack[sp - 3] << 8) | (_stack[sp - 2] << 16) | (_stack[sp - 1] << 24);
        sp = sp - 4;
        ip = _stack[sp - 4] | (_stack[sp - 3] << 8) | (_stack[sp - 2] << 16) | (_stack[sp - 1] << 24);
        sp = sp - 4;
        sp = sp - nargs * 9;
        _stack[sp] = rv_tag;
        _stack[sp + 1] = rv_val;
        sp = sp + 9;
    };

    instruction enter_op = { 01000101, imm32 as count } {
        sp = sp + count * 9;
        ip = ip + 5;
    };

    instruction hlt_op = { 01001111 } {
    };

    instruction lio_op = { 01010000, imm32 as port } {
        io = port;
        ip = ip + 5;
    };

    instruction io_read_op = { 01010001 } {
        sp = sp + 9;
        if io == 0 then {
            _stack[sp - 9] = stdin_tag;
            _stack[sp - 8] = stdin_val;
        }
        ip = ip + 1;
    };

    instruction io_write_op = { 01010010 } {
        if io == 1 then {
            let tag = _stack[sp - 9];
            let val = _stack[sp - 8];
            stdout_full = (tag << 64) | val;
        }
        sp = sp - 9;
        ip = ip + 1;
    };

    instruction init_sp_op = { 00001111, imm32 as value } {
        sp = value;
        ip = ip + 5;
    };

    instruction jnz_op = { 01000001, addr32 as target } {
        if _stack[sp - 8] != 0 then {
            ip = target;
        } else {
            ip = ip + 5;
        }
        sp = sp - 9;
    };

mnemonics:
    format plain1 is "{1}";

    mnemonic push_int   for push_int_op   (value) plain1;
    mnemonic push_bool  for push_bool_op  (value) plain1;
    mnemonic push_char  for push_char_op  (value) plain1;
    mnemonic push_const for push_const_op (idx)   plain1;
    mnemonic push_none  for push_none_op  ();
    mnemonic load_local  for load_local_op  (slot) plain1;
    mnemonic store_local for store_local_op (slot) plain1;
    mnemonic load_arg    for load_arg_op    (slot) plain1;
    mnemonic store_arg   for store_arg_op   (slot) plain1;
    mnemonic dup for dup_op ();
    mnemonic pop for pop_op ();
    mnemonic add for add_op ();
    mnemonic sub for sub_op ();
    mnemonic mul for mul_op ();
    mnemonic div for div_op ();
    mnemonic mod for mod_op ();
    mnemonic neg for neg_op ();
    mnemonic inc for inc_op ();
    mnemonic dec for dec_op ();
    mnemonic bit_and for bit_and_op ();
    mnemonic bit_or  for bit_or_op  ();
    mnemonic bit_xor for bit_xor_op ();
    mnemonic bit_shl for bit_shl_op ();
    mnemonic bit_shr for bit_shr_op ();
    mnemonic bit_not for bit_not_op ();
    mnemonic log_and for log_and_op ();
    mnemonic log_or  for log_or_op  ();
    mnemonic log_not for log_not_op ();
    mnemonic cmp_eq for cmp_eq_op ();
    mnemonic jmp  for jmp_op  (target) plain1;
    mnemonic call for call_op (target) plain1;
    mnemonic ret  for ret_op  (nargs)  plain1;
    mnemonic enter for enter_op (count) plain1;
    mnemonic hlt   for hlt_op  ();
    mnemonic lio       for lio_op       (port) plain1;
    mnemonic io_read   for io_read_op   ();
    mnemonic io_write  for io_write_op  ();
    mnemonic init_sp for init_sp_op (value) plain1;
    mnemonic jnz for jnz_op (target) plain1;

}